# Used by `docker compose up`. Copy to `.env` (same directory as
# docker-compose.yml) — Compose loads it automatically for variable
# substitution below; it is not read by the app code directly.

JAMAI_TOKEN=your-personal-access-token
JAMAI_PROJECT_ID=proj_9f386b9e35a4f019119bfc11
JAMAI_API_BASE=https://api.jamaibase.com/api

# Action tables created by the teacher/admin in the JamAI Base console.
# See jamai/connector.py for the input/output columns each one needs.
JAMAI_EXTRACTION_TABLE_ID=Question_extraction
JAMAI_SCORING_TABLE_ID=Subjective_test_scoring
JAMAI_GENERATION_TABLE_ID=Exam_generation

# Must be a URL the *browser* can reach (it's baked into the frontend's
# client bundle at build time), not an internal Docker hostname.
NEXT_PUBLIC_API_BASE=http://localhost:8002

# Host-side port overrides, only needed if 3000/8002 are already taken on
# your machine. If you change BACKEND_PORT, update NEXT_PUBLIC_API_BASE above
# to match.
# FRONTEND_PORT=3000
# BACKEND_PORT=8002
